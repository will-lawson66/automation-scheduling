<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <UI Id="CustomUI">
      <UIRef Id="WixUI_Mondo" />
      <UIRef Id="WixUI_ErrorProgressText" />
      
      <!-- Replace default bitmaps with corporate branding -->
      <WixVariable Id="WixUIBannerBmp" Value="Resources\banner.jpg" />
      <WixVariable Id="WixUIDialogBmp" Value="Resources\dialog.jpg" />
      <WixVariable Id="WixUILicenseRtf" Value="Resources\license.rtf" />
      
      <!-- Insert custom dialog into the sequence -->
      <Publish Dialog="LicenseAgreementDlg" Control="Next" Event="NewDialog" Value="ConfigurationSelectionDlg">LicenseAccepted = "1"</Publish>
      <Publish Dialog="ConfigurationSelectionDlg" Control="Back" Event="NewDialog" Value="LicenseAgreementDlg">1</Publish>
      <Publish Dialog="ConfigurationSelectionDlg" Control="Next" Event="NewDialog" Value="SetupTypeDlg">1</Publish>
      <Publish Dialog="SetupTypeDlg" Control="Back" Event="NewDialog" Value="ConfigurationSelectionDlg">1</Publish>
      
      <!-- Custom progress text for downloading artifacts -->
      <ProgressText Action="DownloadArtifacts">Downloading artifacts from Azure DevOps...</ProgressText>
      <ProgressText Action="UpdateConfigurationFiles">Updating configuration files...</ProgressText>
      <ProgressText Action="UpdateAppSettings">Configuring application settings...</ProgressText>
    </UI>
  </Fragment>
</Wix>