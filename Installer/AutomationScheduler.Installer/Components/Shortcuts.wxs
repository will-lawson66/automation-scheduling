<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <ComponentGroup Id="ShortcutComponents">
      <!-- Start Menu shortcuts -->
      <Component Id="ApplicationShortcuts" Guid="AAAAAAAA-AAAA-AAAA-AAAA-AAAAAAAAAAAA" Directory="ApplicationProgramsFolder">
        <Shortcut Id="ConsoleApp1StartMenuShortcut"
                  Name="Console App 1"
                  Description="Automation Scheduler Console Application 1"
                  Target="[INSTALLFOLDER]ConsoleApp1.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  IconFile="[INSTALLFOLDER]ConsoleApp1.exe"
                  IconIndex="0" />
                  
        <Shortcut Id="ConsoleApp2StartMenuShortcut"
                  Name="Console App 2"
                  Description="Automation Scheduler Console Application 2"
                  Target="[INSTALLFOLDER]ConsoleApp2.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  IconFile="[INSTALLFOLDER]ConsoleApp2.exe"
                  IconIndex="0" />
                  
        <Shortcut Id="ConsoleApp3StartMenuShortcut"
                  Name="Console App 3"
                  Description="Automation Scheduler Console Application 3"
                  Target="[INSTALLFOLDER]ConsoleApp3.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  IconFile="[INSTALLFOLDER]ConsoleApp3.exe"
                  IconIndex="0" />
                  
        <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall"/>
        <RegistryValue Root="HKCU" Key="Software\[Manufacturer]\[ProductName]" Name="installed" Type="integer" Value="1" KeyPath="yes"/>
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>