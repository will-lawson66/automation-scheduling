{
  "_comment": "email.schema.json - Schema for email automation module",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Email Automation Configuration",
  "required": ["smtp", "templates"],
  "properties": {
    "smtp": {
      "type": "object",
      "required": ["server", "port"],
      "properties": {
        "server": {
          "type": "string",
          "format": "hostname",
          "description": "SMTP server hostname"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "default": 587
        },
        "security": {
          "type": "string",
          "enum": ["none", "ssl", "tls"],
          "default": "tls"
        },
        "authentication": {
          "type": "object",
          "required": ["username"],
          "properties": {
            "username": {
              "type": "string",
              "minLength": 1
            },
            "passwordSource": {
              "type": "string",
              "enum": ["environment", "keyvault", "file"],
              "default": "environment"
            }
          }
        },
        "connectionTimeout": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 60000,
          "default": 30000,
          "description": "Connection timeout in milliseconds"
        },
        "retryPolicy": {
          "type": "object",
          "properties": {
            "maxRetries": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10,
              "default": 3
            },
            "retryDelay": {
              "type": "integer",
              "minimum": 1000,
              "default": 5000,
              "description": "Delay between retries in milliseconds"
            }
          }
        }
      }
    },
    "templates": {
      "type": "object",
      "properties": {
        "basePath": {
          "type": "string",
          "default": "./templates"
        },
        "defaultTemplate": {
          "type": "string",
          "default": "default.html"
        },
        "cacheEnabled": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "processing": {
      "type": "object",
      "properties": {
        "batchSize": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 50
        },
        "maxConcurrentSends": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "default": 5
        },
        "queueProcessingInterval": {
          "type": "integer",
          "minimum": 1000,
          "default": 10000,
          "description": "Queue processing interval in milliseconds"
        }
      }
    }
  }
}

