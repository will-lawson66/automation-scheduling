    class SequenceGroupManager {
        -ConcurrentDictionary~Guid, SequenceGroup~ _sequenceGroups
        -ConcurrentDictionary~Guid, HardwareExecutionPlan~ _executionPlans
        -IGrpcGateway _grpcGateway
        -ILogger~SequenceGroupManager~ _logger
        -SemaphoreSlim _executionSemaphore
        -CancellationTokenSource _cancellationTokenSource
        -Timer _monitoringTimer
        +SequenceGroupManager(grpcGateway, logger)
        +AddSequenceGroup(sequenceGroup: SequenceGroup): Task~bool~
        +RemoveSequenceGroup(sequenceGroupId: Guid): Task~bool~
        +ExecuteSequenceGroup(sequenceGroupId: Guid): Task~ExecutionResult~
        +CancelSequenceGroup(sequenceGroupId: Guid): Task~bool~
