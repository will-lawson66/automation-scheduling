        +GetExecutionStatus(): ExecutionStatus
        +OnSequenceGroupCompleted: EventHandler~SequenceGroupCompletedEventArgs~
        +OnSequenceGroupFailed: EventHandler~SequenceGroupFailedEventArgs~
    }

