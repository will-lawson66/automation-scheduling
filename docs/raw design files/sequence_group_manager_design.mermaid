    %% Relationships
    SequenceGroupManager --> SequenceGroup : manages
    SequenceGroupManager --> HardwareExecutionPlan : creates
    SequenceGroupManager --> IGrpcGateway : communicates via
    SequenceGroupManager --> ExecutionResult : returns

    SequenceGroup --> Sequence : contains
    SequenceGroup --> SequenceResult : produces
    SequenceGroup --> SequenceGroupStatus : has

    HardwareExecutionPlan --> SequenceExecutionStep : contains
    HardwareExecutionPlan --> ExecutionProgress : tracks
    HardwareExecutionPlan --> ExecutionPlanStatus : has

    SequenceExecutionStep --> Sequence : executes
    SequenceExecutionStep --> ResourceRequirement : requires
    SequenceExecutionStep --> SequenceStepStatus : has

    Sequence --> ResourceRequirement : requires
    Sequence --> SequenceStatus : has
    Sequence --> SequenceType : typed as

    ExecutionResult --> SequenceResult : contains
    SequenceResult --> Sequence : results from