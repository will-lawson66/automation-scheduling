    %% Enums
    class SequenceGroupStatus {
        <<enumeration>>
        Created
        Queued
        InProgress
        Completed
        Failed
        Cancelled
    }

    class SequenceStatus {
        <<enumeration>>
        Created
        Queued
        InProgress
        Completed
        Failed
        Cancelled
